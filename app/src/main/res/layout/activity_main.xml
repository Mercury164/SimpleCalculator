<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/calculator_background">

    <TextView
        android:id="@+id/tvExpression"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingTop="24dp"
        android:textColor="@color/calculator_subtext"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text="0"
        android:textColor="@android:color/white"
        android:textSize="44sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:alignmentMode="alignMargins"
        android:columnCount="4"
        android:rowCount="5"
        android:useDefaultMargins="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClear"
            style="@style/Widget.SimpleCalculator.Button.Action"
            android:text="C" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.SimpleCalculator.Button.Action"
            android:text="⌫" />

        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDivide"
            style="@style/Widget.SimpleCalculator.Button.Operation"
            android:text="÷" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="7" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="9" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMultiply"
            style="@style/Widget.SimpleCalculator.Button.Operation"
            android:text="×" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="4" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="5" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubtract"
            style="@style/Widget.SimpleCalculator.Button.Operation"
            android:text="-" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="3" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdd"
            style="@style/Widget.SimpleCalculator.Button.Operation"
            android:text="+" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:layout_columnSpan="2"
            android:text="0"
            app:cornerRadius="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDot"
            style="@style/Widget.SimpleCalculator.Button.Number"
            android:text="." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEquals"
            style="@style/Widget.SimpleCalculator.Button.Equal"
            android:text="=" />
    </GridLayout>

</LinearLayout>
