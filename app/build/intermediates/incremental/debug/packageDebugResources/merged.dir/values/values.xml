<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="calculator_action">#374151</color>
    <color name="calculator_background">#101418</color>
    <color name="calculator_equal">#10B981</color>
    <color name="calculator_number">#1F2937</color>
    <color name="calculator_operation">#F59E0B</color>
    <color name="calculator_subtext">#9CA3AF</color>
    <color name="calculator_text">#FFFFFF</color>
    <color name="ic_launcher_background">#0F172A</color>
    <string name="app_name">Simple Calculator</string>
    <string name="error_division_by_zero">Error</string>
    <style name="Theme.SimpleCalculator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/calculator_operation</item>
        <item name="colorPrimaryVariant">@color/calculator_operation</item>
        <item name="colorOnPrimary">@color/calculator_text</item>
        <item name="colorSecondary">@color/calculator_equal</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/calculator_background</item>
    </style>
    <style name="Widget.SimpleCalculator.Button.Action" parent="Widget.SimpleCalculator.Button.Base">
        <item name="backgroundTint">@color/calculator_action</item>
    </style>
    <style name="Widget.SimpleCalculator.Button.Base" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/calculator_text</item>
        <item name="backgroundTint">@color/calculator_number</item>
    </style>
    <style name="Widget.SimpleCalculator.Button.Equal" parent="Widget.SimpleCalculator.Button.Base">
        <item name="backgroundTint">@color/calculator_equal</item>
    </style>
    <style name="Widget.SimpleCalculator.Button.Number" parent="Widget.SimpleCalculator.Button.Base">
        <item name="backgroundTint">@color/calculator_number</item>
    </style>
    <style name="Widget.SimpleCalculator.Button.Operation" parent="Widget.SimpleCalculator.Button.Base">
        <item name="backgroundTint">@color/calculator_operation</item>
    </style>
</resources>